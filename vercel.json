{
  "crons": [
    {
      "path": "/api/market/update",
      "schedule": "40 6 * * 1-5"
    },
    {
      "path": "/api/notify?type=morning",
      "schedule": "30 23 * * 0-4"
    },
    {
      "path": "/api/notify?type=evening",
      "schedule": "45 6 * * 1-5"
    },
    {
      "path": "/api/signals/generate",
      "schedule": "30 7 * * 1-5"
    },
    {
      "path": "/api/signals/track",
      "schedule": "50 7 * * 1-5"
    }
  ]
}
